# ── Python artifacts ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── IDE / editor files ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ── Secrets — NEVER bake these into the image ─────────────────────────────────
.env
*.env
secrets/

# ── Uploaded files (mounted as a volume in production) ────────────────────────
uploads/

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Docs / test artifacts ──────────────────────────────────────────────────────
*.md
tests/
